# 腾讯云 EdgeOne 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== Supabase 数据库配置 ====================
# 这些配置用于数据持久化存储

# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ==================== EdgeOne 配置 ====================

# 运行环境
NODE_ENV=production

# 服务端口（EdgeOne 会自动分配，本地测试使用）
PORT=3000
