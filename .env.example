# 库房管理系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置（本地PostgreSQL） ====================

# 数据库主机（默认localhost）
DB_HOST=localhost

# 数据库端口（默认5432）
DB_PORT=5432

# 数据库名称
DB_NAME=warehouse

# 数据库用户
DB_USER=postgres

# 数据库密码
DB_PASSWORD=postgres

# ==================== 其他配置（可选） ====================

# 服务端口（默认：3000）
PORT=3000

# 运行环境
NODE_ENV=production
