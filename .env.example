# 库房管理系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置（必需，用于数据持久化） ====================

# Supabase 项目 URL
# 获取方式：登录 Supabase -> 项目设置 -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key（公开密钥）
# 获取方式：登录 Supabase -> 项目设置 -> API -> Project API keys -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key（服务角色密钥，仅后端使用，可选）
# 获取方式：登录 Supabase -> 项目设置 -> API -> Project API keys -> service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==================== 其他配置（可选） ====================

# 服务端口（默认：8080）
PORT=8080

# 运行环境
NODE_ENV=production
